# Example environment variables for the Shepherd's Stories backend application.

# Optional
APP_NAME="shepherds_stories_backend"
DB_DATABASE="shepherds_stories"
DB_HOST="localhost"
DB_PORT="5432"

# Required
DB_USERNAME="your_username"
DB_PASSWORD="your_password"

DATABASE_URL="jdbc:postgresql://localhost:5432/your_database_name?schema=public"

GOOGLE_CLIENT_ID="your_client_id"
GOOGLE_CLIENT_SECRET="your_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:8080/api/auth/google/callback"
GOOGLE_SCOPE="profile email"

AWS_ACCESS_KEY="your_access_key"
AWS_SECRET_KEY="your_secret_key"
AWS_REGION="your_region"
AWS_S3_BUCKET="your_bucket_name"